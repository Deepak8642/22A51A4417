# ─────────────────────────────────────────────────────────────────────────────
#  IMPORTS
# ─────────────────────────────────────────────────────────────────────────────
import sys
import os
import re
import glob
from collections import defaultdict

import pdfplumber
from openpyxl import Workbook
from openpyxl.styles import (
    Font, PatternFill, Alignment, Border, Side,
    GradientFill
)
from openpyxl.utils import get_column_letter


# ─────────────────────────────────────────────────────────────────────────────
#  TUNING CONSTANTS
# ─────────────────────────────────────────────────────────────────────────────
Y_SNAP          = 1.8   # pt — chars within this vertical band → same row
SEG_GAP         = 7.0   # pt — horizontal gap bigger than this → new segment
VLINE_MIN       = 2     # need ≥ this many PDF v-lines to use GRID mode
TABLE_MIN_COLS  = 2     # pdfplumber table needs ≥ this many columns
COL_SNAP_GRID   = 4     # pt — snap nearby v-line x-positions together
COL_SNAP_TEXT   = 6     # pt — snap nearby text x0 positions together
FILL_WIDTH_FRAC = 0.20  # rect must be ≥ this fraction of page width to be a header fill


# ─────────────────────────────────────────────────────────────────────────────
#  COLOUR & STYLE PALETTE
# ─────────────────────────────────────────────────────────────────────────────
# Cell colours
C_WHITE      = "FFFFFF"
C_STRIPE     = "F7F7F7"   # alternating row shade
C_HDR_GREY   = "D9D9D9"   # grey background header
C_HDR_BLACK  = "1F1F1F"   # black background header
C_HDR_BLUE   = "17375E"   # deep blue — column label headers
C_HDR_LBLUE  = "BDD7EE"   # light blue — sub-header rows
C_HDR_GREEN  = "E2EFDA"   # light green — total rows
C_TITLE_BG   = "2E4057"   # page title bar background

# Border presets
def _side(style="thin", color="BBBBBB"):
    return Side(style=style, color=color)

def _border(style="thin", color="BBBBBB"):
    s = _side(style, color)
    return Border(top=s, bottom=s, left=s, right=s)

BORDER_THIN   = _border("thin",   "CCCCCC")
BORDER_MEDIUM = _border("medium", "888888")
BORDER_THICK  = _border("medium", "333333")
BORDER_NONE   = Border()

def _fill(hex6):
    return PatternFill("solid", fgColor=hex6)

def _font(bold=False, size=9, color="111111", italic=False):
    return Font(name="Calibri", bold=bold, size=max(int(size), 7),
                color=color, italic=italic)

def _align(h="left", v="center", wrap=True):
    return Alignment(horizontal=h, vertical=v, wrap_text=wrap)


# ─────────────────────────────────────────────────────────────────────────────
#  CELL WRITER  — central routine so styling is consistent everywhere
# ─────────────────────────────────────────────────────────────────────────────
def write_cell(cell, value,
               bold=False, size=9, fg="111111", bg=C_WHITE,
               align="left", border=None, wrap=True, italic=False):
    """Write value + full formatting to one cell."""
    cell.value         = str(value) if value is not None else ""
    cell.number_format = "@"          # FORCE TEXT — never auto-reformat
    cell.font          = _font(bold=bold, size=size, color=fg, italic=italic)
    cell.fill          = _fill(bg)
    cell.alignment     = _align(align, wrap=wrap)
    cell.border        = border if border is not None else BORDER_THIN


def safe_merge(ws, r1, c1, r2, c2):
    if r1 == r2 and c1 == c2:
        return
    try:
        ws.merge_cells(start_row=r1, start_column=c1,
                       end_row=r2,   end_column=c2)
    except Exception:
        pass


# ─────────────────────────────────────────────────────────────────────────────
#  SNAP UTILITY — merge nearby coordinate values
# ─────────────────────────────────────────────────────────────────────────────
def snap_vals(vals, tol):
    out = []
    for v in sorted(set(round(float(x), 2) for x in vals)):
        if out and v - out[-1] <= tol:
            out[-1] = (out[-1] + v) / 2.0
        else:
            out.append(v)
    return sorted(out)


# ─────────────────────────────────────────────────────────────────────────────
#  CHAR → ROW GROUPING
# ─────────────────────────────────────────────────────────────────────────────
def chars_to_visual_rows(chars, y_snap=Y_SNAP):
    """Group PDF chars into visual rows by y-coordinate proximity."""
    buckets = defaultdict(list)
    for ch in chars:
        key = round(float(ch["top"]) / y_snap) * y_snap
        buckets[key].append(ch)

    rows = []
    for k in sorted(buckets):
        chs = sorted(buckets[k], key=lambda c: float(c["x0"]))
        avg_y = sum(float(c["top"]) for c in chs) / len(chs)
        rows.append((avg_y, chs))
    return rows


# ─────────────────────────────────────────────────────────────────────────────
#  ROW → SEGMENT SPLITTING
# ─────────────────────────────────────────────────────────────────────────────
def chars_to_segments(chs, gap=SEG_GAP):
    """
    Split a row's chars into x-gap segments.
    Dot leaders (.....) are absorbed into the preceding segment.
    """
    if not chs:
        return []

    chs = sorted(chs, key=lambda c: float(c["x0"]))
    groups = [[chs[0]]]
    for i in range(1, len(chs)):
        if float(chs[i]["x0"]) - float(chs[i - 1]["x1"]) > gap:
            groups.append([])
        groups[-1].append(chs[i])

    result = []
    for g in groups:
        txt = "".join(c["text"] for c in g).strip()
        if not txt:
            continue
        # Detect dot leaders
        is_dots = all(c["text"].strip() in (".", "", " ") for c in g)
        if is_dots:
            # Absorb into previous if it exists, else skip
            if result:
                result[-1]["x1"] = float(g[-1]["x1"])
            continue
        result.append(dict(
            x0   = float(g[0]["x0"]),
            x1   = float(g[-1]["x1"]),
            text = txt,
            bold = any("Bold" in str(c.get("fontname", "")) or
                       "bold" in str(c.get("fontname", "")).lower()
                       for c in g),
            size = float(g[0].get("size") or 9),
        ))
    return result


# ─────────────────────────────────────────────────────────────────────────────
#  BACKGROUND FILL DETECTION
# ─────────────────────────────────────────────────────────────────────────────
def get_background_fills(page):
    """Return list of significant background fills: black or grey headers."""
    pw  = float(page.width)
    out = []
    for r in page.rects:
        c = r.get("non_stroking_color")
        if c is None:
            continue
        if isinstance(c, (int, float)):
            c = (float(c),) * 3
        if not (isinstance(c, (list, tuple)) and len(c) >= 3):
            continue
        r0, g0, b0 = float(c[0]), float(c[1]), float(c[2])

        if   r0 < 0.20 and g0 < 0.20 and b0 < 0.20:
            kind = "black"
        elif (r0 > 0.40 and g0 > 0.40 and b0 > 0.40 and
              not (r0 > 0.94 and g0 > 0.94 and b0 > 0.94)):
            kind = "grey"
        else:
            continue

        fw = float(r["x1"] - r["x0"])
        if fw > pw * FILL_WIDTH_FRAC:
            out.append(dict(
                top    = float(r["top"]),
                bottom = float(r["bottom"]),
                x0     = float(r["x0"]),
                x1     = float(r["x1"]),
                kind   = kind,
            ))
    return out


def fill_kind_at(y, fills, tol=4.0):
    """Return fill kind ('black'/'grey') at y-coordinate, or None."""
    for f in fills:
        if f["top"] - tol <= y <= f["bottom"] + tol:
            return f["kind"]
    return None


# ─────────────────────────────────────────────────────────────────────────────
#  COLUMN SLOT SYSTEM
# ─────────────────────────────────────────────────────────────────────────────
def build_slots_from_vlines(page):
    """Column slots from PDF's drawn vertical lines."""
    xs = [float(l["x0"]) for l in page.lines if abs(l["x0"] - l["x1"]) < 1.5]
    xs += [0.0, float(page.width)]
    return snap_vals(xs, COL_SNAP_GRID)


def build_slots_from_text(all_segs, page_width):
    """
    Column slots from segment x0 positions ONLY.
    Using x0 only (not x1) prevents false slot collisions where two
    segments both map to the same column slot.
    """
    xs = {0.0, float(page_width)}
    for segs in all_segs:
        for s in segs:
            xs.add(s["x0"])   # x0 only — critical for correctness
    return snap_vals(list(xs), COL_SNAP_TEXT)


def slot_of(x, slots):
    """Return the 0-based slot index for x-coordinate x."""
    best = 0
    for i in range(len(slots) - 1):
        if slots[i] - 3 <= x:
            best = i
    return best


def end_slot_for(seg_idx, segs, slots):
    """
    End slot for segs[seg_idx] = slot just before the next segment starts.
    Falls back to the segment's own start slot (no span) if it's the last.
    This prevents one segment from eating the column of the next.
    """
    ci_s = slot_of(segs[seg_idx]["x0"], slots)
    if seg_idx + 1 < len(segs):
        ci_next = slot_of(segs[seg_idx + 1]["x0"], slots)
        return max(ci_s, ci_next - 1)
    # Last segment — span to its own x1
    return max(ci_s, slot_of(segs[seg_idx]["x1"], slots))


def guess_alignment(seg, slot_x0, slot_x1):
    """Detect left / center / right alignment from segment position within slot."""
    slot_w = slot_x1 - slot_x0
    if slot_w < 5:
        return "left"
    mid_seg  = (seg["x0"] + seg["x1"]) / 2.0
    mid_slot = (slot_x0 + slot_x1) / 2.0
    if abs(mid_seg - mid_slot) <= slot_w * 0.22:
        return "center"
    if seg["x0"] > slot_x0 + slot_w * 0.52:
        return "right"
    return "left"


# ─────────────────────────────────────────────────────────────────────────────
#  WRITE A SINGLE VISUAL LINE  (GRID / TEXT modes)
# ─────────────────────────────────────────────────────────────────────────────
def write_line(ws, xl_row, segs, slots, n_slots, fill_kind):
    """
    Write one visual line of PDF content to Excel row xl_row.
    Uses sub-row overflow: if two segments land on the same column slot,
    the second goes to xl_row+1 — so NOTHING is ever dropped.
    Returns the number of Excel rows consumed (1 or more).
    """
    if not segs:
        ws.row_dimensions[xl_row].height = 5
        return 1

    sz = segs[0]["size"] if segs else 9

    # ── BLACK full-width section header ──────────────────────────────────────
    if fill_kind == "black":
        txt = "  " + "  ".join(s["text"] for s in segs)
        c   = ws.cell(row=xl_row, column=1)
        write_cell(c, txt,
                   bold=True, size=max(int(sz), 9),
                   fg="FFFFFF", bg=C_HDR_BLACK,
                   align="left", border=BORDER_THICK)
        ws.row_dimensions[xl_row].height = 15
        if n_slots > 1:
            safe_merge(ws, xl_row, 1, xl_row, n_slots)
        return 1

    # ── GREY column/sub header ────────────────────────────────────────────────
    if fill_kind == "grey":
        used = set()
        for si, seg in enumerate(segs):
            ci_s = slot_of(seg["x0"], slots)
            ci_e = end_slot_for(si, segs, slots)
            col  = ci_s + 1
            if col in used:
                continue
            al = guess_alignment(seg,
                                  slots[ci_s],
                                  slots[min(ci_s + 1, len(slots) - 1)])
            c = ws.cell(row=xl_row, column=col)
            write_cell(c, seg["text"],
                       bold=True, size=max(int(seg["size"]), 8),
                       fg="111111", bg=C_HDR_GREY,
                       align=al, border=BORDER_THIN)
            if ci_e > ci_s:
                safe_merge(ws, xl_row, col, xl_row, ci_e + 1)
                for x in range(col, ci_e + 2):
                    used.add(x)
            else:
                used.add(col)
        ws.row_dimensions[xl_row].height = 13
        return 1

    # ── NORMAL DATA ROW  with sub-row overflow ────────────────────────────────
    ws.row_dimensions[xl_row].height = max(11, round(sz * 1.65))

    # Map each segment to a sub-row where its slots are free
    slot_used   = defaultdict(set)   # sub_row_index → set of occupied col numbers
    placements  = []                 # (sub_row, ci_s, ci_e, seg)

    for si, seg in enumerate(segs):
        ci_s  = slot_of(seg["x0"], slots)
        ci_e  = end_slot_for(si, segs, slots)
        sub   = 0
        while any((ci_s + 1 + k) in slot_used[sub]
                  for k in range(ci_e - ci_s + 1)):
            sub += 1
        placements.append((sub, ci_s, ci_e, seg))
        for k in range(ci_e - ci_s + 1):
            slot_used[sub].add(ci_s + 1 + k)

    n_sub = max(p[0] for p in placements) + 1

    for sub, ci_s, ci_e, seg in placements:
        row = xl_row + sub
        bg  = C_STRIPE if row % 2 == 0 else C_WHITE
        al  = guess_alignment(seg,
                               slots[ci_s],
                               slots[min(ci_s + 1, len(slots) - 1)])
        c   = ws.cell(row=row, column=ci_s + 1)
        write_cell(c, seg["text"],
                   bold=seg["bold"], size=max(int(seg["size"]), 8),
                   fg="111111", bg=bg,
                   align=al, border=BORDER_THIN)
        ws.row_dimensions[row].height = max(11, round(sz * 1.65))
        if ci_e > ci_s:
            safe_merge(ws, row, ci_s + 1, row, ci_e + 1)

    return n_sub


# ─────────────────────────────────────────────────────────────────────────────
#  MODE 1 — GRID  (PDF has drawn vertical lines)
# ─────────────────────────────────────────────────────────────────────────────
def write_grid_page(ws, page):
    """Convert a page that has drawn grid lines to Excel."""
    pw        = float(page.width)
    fills     = get_background_fills(page)
    vis_rows  = chars_to_visual_rows(page.chars)
    all_segs  = [chars_to_segments(chs) for _, chs in vis_rows]

    slots   = build_slots_from_vlines(page)
    n_slots = max(len(slots) - 1, 1)

    # Set column widths proportional to PDF column widths
    for ci in range(n_slots):
        cw  = slots[ci + 1] - slots[ci]
        ltr = get_column_letter(ci + 1)
        ws.column_dimensions[ltr].width = max(4, round(cw / 5.5))

    xl_row = 1
    for li, (y, _chs) in enumerate(vis_rows):
        segs = all_segs[li]
        fk   = fill_kind_at(y, fills)
        if not segs:
            ws.row_dimensions[xl_row].height = 5
            xl_row += 1
            continue
        xl_row += write_line(ws, xl_row, segs, slots, n_slots, fk)


# ─────────────────────────────────────────────────────────────────────────────
#  MODE 2 — TABLE  (pdfplumber finds structured tables)
# ─────────────────────────────────────────────────────────────────────────────
def write_table_page(ws, page, tables):
    """
    Convert a page using pdfplumber's table extractor.
    Free-text rows outside tables are handled with positional TEXT logic.
    """
    pw       = float(page.width)
    fills    = get_background_fills(page)
    vis_rows = chars_to_visual_rows(page.chars)
    all_segs = [chars_to_segments(chs) for _, chs in vis_rows]

    # Build a quick lookup of (top, bottom) for each table
    table_spans = [(t.bbox[1], t.bbox[3], t.extract()) for t in tables]

    def y_in_table(y):
        for top, bot, _ in table_spans:
            if top - 5 <= y <= bot + 5:
                return True
        return False

    xl_row          = 1
    tables_written  = set()   # track which table indexes have been emitted

    for li, (y, _chs) in enumerate(vis_rows):
        # ── check if a new table starts at this y position ───────────────────
        for tidx, (ttop, tbot, tdata) in enumerate(table_spans):
            if tidx not in tables_written and abs(y - ttop) < 10:
                tables_written.add(tidx)
                if not tdata:
                    continue

                ncols   = max((len(r) for r in tdata if r), default=1)
                cw_each = max(4, round((pw / ncols) / 5.5))
                for ci in range(ncols):
                    ltr = get_column_letter(ci + 1)
                    if ws.column_dimensions[ltr].width < cw_each:
                        ws.column_dimensions[ltr].width = cw_each

                is_header = True
                for trow in tdata:
                    if trow is None:
                        xl_row += 1
                        continue
                    cells = [str(v).strip() if v is not None else "" for v in trow]
                    if all(cell == "" for cell in cells):
                        xl_row += 1
                        continue

                    ws.row_dimensions[xl_row].height = 14

                    if is_header:
                        # Blue header row
                        for ci, val in enumerate(cells):
                            c = ws.cell(row=xl_row, column=ci + 1)
                            write_cell(c, val,
                                       bold=True, size=9,
                                       fg="FFFFFF", bg=C_HDR_BLUE,
                                       align="center", border=BORDER_MEDIUM)
                        is_header = False
                    else:
                        bg = C_STRIPE if xl_row % 2 == 0 else C_WHITE
                        for ci, val in enumerate(cells):
                            is_num = bool(re.match(r'^-?[\d,]+\.?\d*$',
                                                    val.replace(" ", "")))
                            c = ws.cell(row=xl_row, column=ci + 1)
                            write_cell(c, val,
                                       bold=False, size=9,
                                       fg="111111", bg=bg,
                                       align="right" if is_num else "left",
                                       border=BORDER_THIN)
                    xl_row += 1
                continue   # skip free-text handling for this y

        # ── free-text row outside any table ──────────────────────────────────
        if y_in_table(y):
            continue

        segs = all_segs[li]
        if not segs:
            ws.row_dimensions[xl_row].height = 5
            xl_row += 1
            continue

        fk  = fill_kind_at(y, fills)
        sz  = segs[0]["size"] if segs else 9
        ws.row_dimensions[xl_row].height = max(11, round(sz * 1.6))

        if fk == "black":
            txt = "  " + "  ".join(s["text"] for s in segs)
            c   = ws.cell(row=xl_row, column=1)
            write_cell(c, txt,
                       bold=True, size=max(int(sz), 9),
                       fg="FFFFFF", bg=C_HDR_BLACK,
                       align="left", border=BORDER_THICK)
            ws.row_dimensions[xl_row].height = 15
        elif fk == "grey":
            for ci2, seg in enumerate(segs):
                c = ws.cell(row=xl_row, column=ci2 + 1)
                write_cell(c, seg["text"],
                           bold=True, size=8,
                           fg="111111", bg=C_HDR_GREY,
                           align="left", border=BORDER_THIN)
        else:
            bg = C_STRIPE if xl_row % 2 == 0 else C_WHITE
            for seg in segs:
                is_right = seg["x0"] > pw * 0.55
                col      = max(1, round(seg["x0"] / (pw / 4)))
                c        = ws.cell(row=xl_row, column=col)
                write_cell(c, seg["text"],
                           bold=seg["bold"],
                           size=max(int(seg["size"]), 8),
                           fg="111111", bg=bg,
                           align="right" if is_right else "left",
                           border=BORDER_THIN)
        xl_row += 1


# ─────────────────────────────────────────────────────────────────────────────
#  MODE 3 — TEXT  (free-form positioned text, no grid, no tables)
# ─────────────────────────────────────────────────────────────────────────────
def write_text_page(ws, page):
    """Convert a page with free-form positioned text."""
    pw       = float(page.width)
    fills    = get_background_fills(page)
    vis_rows = chars_to_visual_rows(page.chars)
    all_segs = [chars_to_segments(chs) for _, chs in vis_rows]

    # Build column slots from text x0 positions
    slots   = build_slots_from_text(all_segs, pw)
    n_slots = max(len(slots) - 1, 1)

    for ci in range(n_slots):
        cw  = slots[ci + 1] - slots[ci]
        ltr = get_column_letter(ci + 1)
        ws.column_dimensions[ltr].width = max(4, round(cw / 5.5))

    xl_row = 1
    for li, (y, _chs) in enumerate(vis_rows):
        segs = all_segs[li]
        fk   = fill_kind_at(y, fills)
        if not segs:
            ws.row_dimensions[xl_row].height = 5
            xl_row += 1
            continue
        xl_row += write_line(ws, xl_row, segs, slots, n_slots, fk)


# ─────────────────────────────────────────────────────────────────────────────
#  PAGE DISPATCHER  — auto-selects the best mode per page
# ─────────────────────────────────────────────────────────────────────────────
def process_page(ws, page):
    """Choose extraction mode and write the page to worksheet."""
    vlines = [l for l in page.lines if abs(l["x0"] - l["x1"]) < 1.5]
    tables = [t for t in page.find_tables()
              if t.extract() and
              max((len(r) for r in t.extract() if r), default=0) >= TABLE_MIN_COLS]

    if len(vlines) >= VLINE_MIN:
        mode = "GRID"
        write_grid_page(ws, page)
    elif tables:
        mode = "TABLE"
        write_table_page(ws, page, tables)
    else:
        mode = "TEXT"
        write_text_page(ws, page)

    # Freeze header row
    ws.freeze_panes = "A2"
    return mode


# ─────────────────────────────────────────────────────────────────────────────
#  WORKBOOK POLISH — applied after all pages are written
# ─────────────────────────────────────────────────────────────────────────────
def polish_workbook(wb):
    """Apply global finishing touches to the workbook."""
    for ws in wb.worksheets:
        # Print settings for nice print output
        ws.page_setup.fitToPage   = True
        ws.page_setup.fitToWidth  = 1
        ws.page_setup.fitToHeight = 0
        ws.sheet_view.showGridLines = True
        # Auto-filter on first row if it has data
        if ws.max_row > 1 and ws.max_column > 1:
            pass   # skip autofilter for form-type sheets


# ─────────────────────────────────────────────────────────────────────────────
#  MAIN CONVERT FUNCTION
# ─────────────────────────────────────────────────────────────────────────────
def convert(pdf_path: str, out_path: str = None) -> str:
    """
    Convert a PDF file to Excel with ditto-print quality.

    Args:
        pdf_path: Path to the input PDF file.
        out_path: Path for the output .xlsx file.
                  Defaults to same name as PDF with .xlsx extension.

    Returns:
        The path of the created .xlsx file.
    """
    if out_path is None:
        out_path = os.path.splitext(pdf_path)[0] + ".xlsx"

    print(f"\n{'═' * 62}")
    print(f"  PDF → Excel  (I Love PDF quality, no API needed)")
    print(f"  Input  : {os.path.basename(pdf_path)}")
    print(f"  Output : {out_path}")
    print(f"{'═' * 62}")

    wb = Workbook()

    with pdfplumber.open(pdf_path) as pdf:
        n_pages = len(pdf.pages)
        for pn, page in enumerate(pdf.pages):
            ws = wb.active if pn == 0 else wb.create_sheet()
            ws.title = f"Page {pn + 1}"

            n_chars  = len(page.chars)
            n_vlines = len([l for l in page.lines if abs(l["x0"] - l["x1"]) < 1.5])
            n_tables = len(page.find_tables())

            print(f"\n  Page {pn + 1}/{n_pages}  "
                  f"({page.width:.0f}×{page.height:.0f}  "
                  f"chars={n_chars}  vlines={n_vlines}  tables={n_tables})",
                  end="  ", flush=True)

            mode = process_page(ws, page)
            print(f"→ [{mode}]  ✓")

    polish_workbook(wb)
    wb.save(out_path)

    print(f"\n{'═' * 62}")
    print(f"  ✓  Saved  {n_pages} page(s)  →  {out_path}")
    print(f"{'═' * 62}\n")
    return out_path


# ─────────────────────────────────────────────────────────────────────────────
#  COMMAND-LINE INTERFACE
# ─────────────────────────────────────────────────────────────────────────────
def _cli():
    if len(sys.argv) < 2:
        print(__doc__)
        print("Usage:")
        print("  python pdf_to_excel_ilovepdf.py  input.pdf")
        print("  python pdf_to_excel_ilovepdf.py  input.pdf  output.xlsx")
        print("  python pdf_to_excel_ilovepdf.py  *.pdf")
        sys.exit(0)

    # Expand any glob patterns (e.g. *.pdf)
    inputs = []
    for arg in sys.argv[1:]:
        if arg.endswith(".xlsx") and len(sys.argv) == 3:
            continue    # this is the output path
        expanded = glob.glob(arg)
        if expanded:
            inputs.extend(expanded)
        elif os.path.exists(arg):
            inputs.append(arg)
        else:
            print(f"  [WARN] Not found or no match: {arg}")

    if not inputs:
        print("No input PDF files found.")
        sys.exit(1)

    # If exactly 2 args and arg[2] ends with .xlsx → it's the output path
    out_path = None
    if len(sys.argv) == 3 and sys.argv[2].lower().endswith(".xlsx"):
        out_path = sys.argv[2]
        if len(inputs) > 1:
            print("[WARN] Output path ignored when converting multiple files.")
            out_path = None

    success = 0
    errors  = 0
    for pdf_path in inputs:
        try:
            dest = out_path if (out_path and len(inputs) == 1) else None
            convert(pdf_path, dest)
            success += 1
        except Exception as e:
            print(f"\n  [ERROR] {pdf_path}: {e}")
            import traceback
            traceback.print_exc()
            errors += 1

    print(f"\n  Summary: {success} converted, {errors} failed.\n")


if __name__ == "__main__":
    _cli()
