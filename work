#  CLI
# ══════════════════════════════════════════════════════════════════════════════
if __name__ == "__main__":
    import argparse
    p = argparse.ArgumentParser(description="PDF → Excel same-to-same replica (Azure GPT-4.1 Vision)")
    p.add_argument("inputs", nargs="+", help="PDF files or glob patterns")
    p.add_argument("-o", "--output", help="Output .xlsx (single file only)")
    p.add_argument("--no-ai", action="store_true", help="Rule-based only (offline, no Azure needed)")
    args = p.parse_args()

    pdfs = []
    for pat in args.inputs:
        exp = glob.glob(pat)
        if exp: pdfs.extend(sorted(exp))
        elif os.path.exists(pat): pdfs.append(pat)
        else: print(f"  Not found: {pat}")

    if not pdfs: print("No PDF files found."); sys.exit(1)

    out    = args.output if (args.output and len(pdfs)==1) else None
    use_ai = not args.no_ai

    ok = fail = 0
    for pdf in pdfs:
        try:
            convert(pdf, out if len(pdfs)==1 else None, use_ai=use_ai)
            ok += 1
        except Exception as e:
            print(f"  ERROR {pdf}: {e}"); import traceback; traceback.print_exc(); fail+=1

    if len(pdfs)>1: print(f"\n  Done: {ok} ok, {fail} failed.")
