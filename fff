# ── per-page decision thresholds ──────────────────────────────────────────────
VLINE_MIN         = 2      # ≥ this many PDF v-lines → GRID mode
TABLE_MIN_COLS    = 2      # pdfplumber table must have ≥ this cols
AI_THRESHOLD      = 200    # pages with < this many chars → always use Vision AI
RENDER_DPI        = 180    # image DPI sent to Azure (higher = more accurate)
RENDER_MAX_W      = 1400   # max image width pixels

# ── cell constants ─────────────────────────────────────────────────────────────
Y_SNAP    = 2.0
SEG_GAP   = 7
COL_SNAP  = 4

# ══════════════════════════════════════════════════════════════════════════════
#  STYLE HELPERS
# ══════════════════════════════════════════════════════════════════════════════
def _fill(h):
    return PatternFill("solid", fgColor=h)

def _side(s="thin", c="CCCCCC"):
    return Side(style=s, color=c)

def _bdr(s="thin", c="CCCCCC"):
    sd = _side(s, c)
    return Border(top=sd, bottom=sd, left=sd, right=sd)

def _fnt(bold=False, sz=9, color="111111"):
    return Font(name="Arial", bold=bold, size=max(int(sz), 7), color=color)

def _aln(h="left", wrap=True):
    return Alignment(horizontal=h, vertical="center", wrap_text=wrap)

def _write(cell, value, bold=False, sz=9, fg="111111", bg="FFFFFF",
           align="left", border=None, wrap=True):
    cell.value         = str(value) if value is not None else ""
    cell.number_format = "@"           # force text — never let Excel reformat
    cell.font          = _fnt(bold=bold, sz=sz, color=fg)
    cell.fill          = _fill(bg)
    cell.alignment     = _aln(align, wrap)
    if border:
        cell.border    = border

THIN  = _bdr("thin",  "CCCCCC")
THICK = _bdr("medium","333333")

# Colour palette
C_WHITE     = "FFFFFF"
C_STRIPE    = "F5F5F5"
C_GREY_HDR  = "DCDCDC"
C_BLUE_HDR  = "2F5496"
C_BLUE_SUB  = "BDD7EE"
C_BLACK_HDR = "1F1F1F"

def safe_merge(ws, r1, c1, r2, c2):
    if r1 == r2 and c1 == c2: return
    try:
        ws.merge_cells(start_row=r1, start_column=c1,
                       end_row=r2, end_column=c2)
    except Exception:
        pass


# ══════════════════════════════════════════════════════════════════════════════
#  IMAGE RENDERING
# ══════════════════════════════════════════════════════════════════════════════
def page_to_b64(pdf_path: str, page_idx: int) -> str | None:
    """Render PDF page to base64 PNG. Returns None if rendering fails."""

    # PyMuPDF — highest quality
    if HAS_FITZ:
        try:
            doc  = fitz.open(pdf_path)
            pg   = doc[page_idx]
            zoom = RENDER_DPI / 72
            pix  = pg.get_pixmap(matrix=fitz.Matrix(zoom, zoom), alpha=False)
            data = pix.tobytes("png")
            doc.close()
            return base64.b64encode(data).decode()
        except Exception as e:
            print(f"      [fitz render failed: {e}]")

    # pdfplumber + PIL fallback
    if HAS_PIL:
        try:
            with pdfplumber.open(pdf_path) as pdf:
                img = pdf.pages[page_idx].to_image(resolution=RENDER_DPI)
                buf = io.BytesIO()
                img.save(buf, format="PNG")
                pil = PILImage.open(io.BytesIO(buf.getvalue()))
                if pil.width > RENDER_MAX_W:
                    ratio = RENDER_MAX_W / pil.width
                    pil   = pil.resize(
                        (RENDER_MAX_W, int(pil.height * ratio)), PILImage.LANCZOS)
                out = io.BytesIO()
                pil.save(out, format="PNG")
                return base64.b64encode(out.getvalue()).decode()
        except Exception as e:
            print(f"      [PIL render failed: {e}]")

    return None


