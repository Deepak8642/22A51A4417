if __name__ == "__main__":
    import argparse
    p = argparse.ArgumentParser(
        description="PDF → Excel ditto print (Azure GPT-4.1 Vision + rule-based)")
    p.add_argument("input",  help="Input PDF")
    p.add_argument("output", nargs="?", help="Output .xlsx (optional)")
    p.add_argument("--no-ai", action="store_true",
                   help="Disable AI, use rule-based only (offline mode)")
    p.add_argument("--ai-all", action="store_true",
                   help="Force AI on every page (overrides threshold)")
    args = p.parse_args()

    if not os.path.exists(args.input):
        print(f"File not found: {args.input}"); sys.exit(1)

    # --ai-all: lower threshold to 0 so every page uses AI
    if args.ai_all:
        AI_THRESHOLD = 0

    convert(args.input, args.output, use_ai=not args.no_ai)
